// WAVE 5A: EMAIL AUTOMATION SYSTEM
// ============================================================================

// EmailCampaign - Automated email campaigns
model EmailCampaign {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  // Campaign details
  name        String
  description String? @db.Text
  type        EmailCampaignType
  status      EmailCampaignStatus @default(DRAFT)

  // Email content
  templateId  String?
  template    EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subject     String
  fromName    String         @default("Flow")
  fromEmail   String         @default("noreply@klinikflow.se")
  replyTo     String?

  // Targeting
  segmentRules Json?          // JSON rules for segment selection
  testGroup    Boolean        @default(false) // If true, only send to test group

  // Scheduling
  triggerType EmailTriggerType
  triggerConfig Json?          // Config for trigger (e.g., {daysAfter: 7, event: "trial_start"})
  
  scheduleType ScheduleType   @default(IMMEDIATE)
  scheduledAt  DateTime?
  recurringRule Json?          // For recurring campaigns

  // Tracking
  totalSent       Int @default(0)
  totalDelivered  Int @default(0)
  totalOpened     Int @default(0)
  totalClicked    Int @default(0)
  totalUnsubscribed Int @default(0)
  totalBounced    Int @default(0)

  // Calculated metrics
  openRate    Decimal? @db.Decimal(5, 4)
  clickRate   Decimal? @db.Decimal(5, 4)
  conversionRate Decimal? @db.Decimal(5, 4)

  // A/B Testing
  isAbTest    Boolean @default(false)
  abTestConfig Json?

  // Email sends
  emailSends EmailSend[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sentAt    DateTime?

  @@index([clinicId])
  @@index([status])
  @@index([type])
  @@index([triggerType])
}

enum EmailCampaignType {
  ONBOARDING      // Welcome series
  TRIAL_NURTURE   // During trial period
  UPGRADE_PROMPT  // Encourage upgrade
  RETENTION       // Keep customers engaged
  WIN_BACK        // Reactivate churned customers
  ANNOUNCEMENT    // Product updates
  EDUCATIONAL     // Tips & best practices
  PROMOTIONAL     // Special offers
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EmailTriggerType {
  MANUAL          // Sent manually
  SCHEDULED       // Specific date/time
  USER_ACTION     // Triggered by user action
  TIME_BASED      // X days after event
  BEHAVIORAL      // Based on behavior
  LIFECYCLE       // Based on customer lifecycle stage
}

enum ScheduleType {
  IMMEDIATE       // Send now
  SCHEDULED       // Send at specific time
  RECURRING       // Recurring schedule
  TRIGGERED       // Triggered by event
}

// EmailTemplate - Reusable email templates
model EmailTemplate {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Template details
  name        String
  description String? @db.Text
  category    String? // "onboarding", "retention", "upgrade", etc.
  
  // Content
  subject     String
  htmlContent String  @db.Text
  textContent String? @db.Text // Plain text version
  
  // Variables
  variables   String[] @default([]) // Available variables like {{firstName}}, {{clinicName}}
  
  // Design
  thumbnailUrl String?
  unlayerDesign Json? // Unlayer JSON design if using Unlayer editor
  
  // Status
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false) // System default template

  // Usage
  campaigns   EmailCampaign[]
  usageCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([category])
  @@index([isActive])
}

// EmailSend - Individual email send tracking
model EmailSend {
  id          String  @id @default(cuid())
  campaignId  String
  campaign    EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  // Recipient
  recipientEmail String
  recipientName  String?
  customerId     String? // If sent to a customer

  // Content
  subject     String
  htmlContent String @db.Text

  // Provider tracking
  providerId     String? // External email provider ID (SendGrid, etc.)
  providerStatus String?

  // Status
  status        EmailSendStatus @default(PENDING)
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  bouncedAt     DateTime?
  unsubscribedAt DateTime?

  // Failure tracking
  failureReason String? @db.Text
  retryCount    Int     @default(0)
  maxRetries    Int     @default(3)

  // Engagement
  openCount     Int     @default(0)
  clickCount    Int     @default(0)

  // Metadata
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([recipientEmail])
  @@index([customerId])
  @@index([status])
  @@index([sentAt])
}

enum EmailSendStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  UNSUBSCRIBED
  FAILED
}

