// UnlayerLicense - Paid Unlayer licenses for Enterprise tier
model UnlayerLicense {
  id        String   @id @default(cuid())
  clinicId  String   @unique
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // License details
  plan           UnlayerPlan         @default(FREE)
  status         UnlayerLicenseStatus @default(ACTIVE)
  apiKey         String?              // Unlayer API key for paid plans
  projectId      String?              // Unlayer Project ID

  // Pricing
  pricePerMonth  Decimal              @default(0) @db.Decimal(10, 2)

  // Validity
  activatedAt    DateTime             @default(now())
  expiresAt      DateTime?
  lastSyncedAt   DateTime?            // Last time we synced with Unlayer API

  // Usage tracking
  emailsSent     Int                  @default(0)
  emailsLimit    Int?                 // Monthly limit (null = unlimited)

  // Metadata
  metadata       Json?                // Additional Unlayer plan details

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([clinicId])
  @@index([status])
  @@index([plan])
  @@index([expiresAt])
}

enum UnlayerPlan {
  FREE          // Free plan (no API key needed)
  LAUNCH        // Paid Launch plan
  SCALE         // Paid Scale plan  
  OPTIMIZE      // Paid Optimize plan
}

enum UnlayerLicenseStatus {
  ACTIVE        // License is active
  EXPIRED       // License has expired
  SUSPENDED     // License is suspended (payment issue)
  CANCELLED     // License cancelled by admin
  PENDING       // License pending activation
}

// Dynamic Pricing Intelligence Log
model DynamicPricingLog {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Action details
  action      DynamicPricingAction // ENABLED or DISABLED
  toggledBy   String?              // User ID who toggled (optional for admin tracking)
  toggledByName String?            // User name for easier tracking

  // Legal compliance tracking
  daysSinceLastToggle Int?         // Days since previous toggle (for 28-day rule)
  
  // Timestamps
  toggledAt DateTime @default(now())

  // Metadata
  metadata  Json?    // Additional context (e.g., warning shown, user acknowledged)

  @@index([clinicId])
  @@index([toggledAt])
  @@index([action])
}

enum DynamicPricingAction {
  ENABLED
  DISABLED
}

