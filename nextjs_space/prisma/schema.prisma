// ===== SALES (FINANCIAL TRANSACTIONS) =====
// ⚠️ IMPORTANT: Sales are separate from Bookings!
// - Sales = Financial transactions (revenue, payments, klippkort)
// - Bookings = Capacity/occupancy tracking (timeslots, staff utilization)
//
// WHY? Klippkort creates mismatch:
// - 1 Sale = Customer buys klippkort (payment happens NOW)
// - Multiple Bookings = Customer uses klippkort stamps later (no payment)
//
// RULE: Use Sales for revenue analysis, Bookings for capacity analysis

// Sale (Receipt/Transaction) - From Bokadirekt /sales endpoint
model Sale {
  id               String   @id @default(cuid())
  bokadirektId     String?  @unique // Bokadirekt receipt number
  clinicId         String?
  customerId       String? // Can be null for anonymous sales
  
  // Transaction details
  receiptDate      DateTime // ← WHEN PAYMENT WAS MADE (not when service used!)
  receiptType      Int      @default(0) // 0=Sale, 1=Refund, etc.
  receiptNumber    String?
  
  // Financial totals
  totalAmount      Decimal  @db.Decimal(10, 2) // Sum of all items
  totalVat         Decimal  @db.Decimal(10, 2) // Total VAT
  totalDiscount    Decimal  @default(0) @db.Decimal(10, 2)
  
  // Relations
  clinic           Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  items            SaleItem[]
  payments         SalePayment[]
  bankTransactions BankTransaction[] // Matched bank transactions from Fortnox
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([clinicId])
  @@index([customerId])
  @@index([receiptDate])
  @@index([receiptType])
}

// SaleItem - Individual line item in a sale (product/service/klippkort)
model SaleItem {
  id               String   @id @default(cuid())
  saleId           String
  sale             Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  // Item details
  itemId           String? // Bokadirekt item ID (product/service)
  name             String?
  itemType         Int      @default(0) // 0=Product, 1=Service, 4=Klippkort, etc.
  
  // Staff/Resource
  staffId          String?
  staffName        String?
  staff            Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  
  // Booking link (optional - null for klippkort purchases)
  bookingId        String?
  booking          Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  
  // Customer (can differ from sale customer for multi-person receipts)
  customerId       String?
  customerName     String?
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  // Financials
  quantity         Int      @default(1)
  pricePerUnit     Decimal  @db.Decimal(10, 2)
  discount         Decimal  @default(0) @db.Decimal(10, 2)
  totalPrice       Decimal  @db.Decimal(10, 2) // After discount, incl VAT
  vatRate          Decimal  @db.Decimal(5, 2) // e.g. 25.00 for 25%
  
  createdAt        DateTime @default(now())
  
  @@index([saleId])
  @@index([staffId])
  @@index([bookingId])
  @@index([customerId])
}

// SalePayment - Payment methods used in a transaction
model SalePayment {
  id           String   @id @default(cuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  paymentType  Int      // 0=Cash, 1=Card, 2=Swish, 3=Invoice, 4=Klippkort, etc.
  amount       Decimal  @db.Decimal(10, 2)
  
  createdAt    DateTime @default(now())
  
  @@index([saleId])
  @@index([paymentType])
}

// ============================================
// RAG KNOWLEDGE BASE
// ============================================

model KnowledgeChunk {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  // Content
  content     String   @db.Text
  contentType String   // "service", "philosophy", "booking_info", "review", "package", "offer"
  
  // Metadata
  category    String?  // "Smärta & Funktion", "Mental Hälsa", "Kost & Stress", etc.
  subcategory String?  // "axelsmärta", "stress", etc.
  
  // Service-specific metadata (if contentType = "service")
  serviceName String?
  duration    Int?     // minutes
  price       Float?   // SEK
  practitioner String? // JSON string or comma-separated names
  
  // Embedding vector for semantic search (requires pgvector extension)
  // NOTE: This is stored as Float[] in Prisma but as vector(1536) in Postgres
  embedding   Float[]
  
  // Source tracking
  sourceUrl   String?
  sourceType  String   // "website", "bokadirekt", "manual"
  
  // Keywords for keyword-based search fallback
  keywords    String[] // Array of searchable keywords
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([clinicId])
  @@index([contentType])
  @@index([category])
  @@index([keywords])
  @@map("knowledge_chunks")
}

// ============================================
// FAQ MANAGEMENT SYSTEM
// ============================================

// FAQ Management System - For Voice AI and customer service
model FAQ {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  question    String   @db.Text
  answer      String   @db.Text
  category    String?  // E.g., "Priser", "Bokningar", "Behandlingar", "Öppettider"
  keywords    String[] @default([]) // For better search matching
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // Higher number = show first in searches
  
  // Usage tracking
  timesUsed   Int      @default(0) // How many times this FAQ was returned
  lastUsedAt  DateTime?
  
  createdBy   String? // User ID who created
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
  @@index([category])
  @@index([isActive])
  @@index([priority])
  @@map("faqs")
}

// ============================================
// BOKADIREKT AUTO-BOOKING
// ============================================

enum BokadirektAutoBookingMode {
  OFF      // No auto-booking
  NOTIFY   // Send notification when slot available
  AUTO     // Automatically book slot
}
