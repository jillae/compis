// PAYATT-MODULEN: LOYALTY, SMS, CAMPAIGNS (additions)
// ============================================================================

// ============================================================================
// PAYATT-MODULEN: LOYALTY, SMS, CAMPAIGNS
// ============================================================================

// CustomerStatus - från Zoezi (Stammis, Terminare, Dansare)
model CustomerStatus {
  id          String  @id @default(cuid())
  sourceId    String? // Original ID från Zoezi (2, 3, 4)
  name        String // "Stammis", "Terminare", "Dansare"
  description String?
  color       String? // Hex color för UI
  isActive    Boolean @default(true)

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, sourceId])
  @@index([clinicId])
}

// LoyaltyProgram - Stämpelkortsprogram
model LoyaltyProgram {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  code        String? // Hemlig kod för kunder att registrera sig

  // Rules (JSON för flexibilitet)
  earnRule   Json // { type: "per_booking", value: 1, minSpend: 500 }
  redeemRule Json // { 10: "free_addon", 20: "discount_20pct" }
  tierRules  Json? // { bronze: 0, silver: 50, gold: 100 }

  // Validity
  startDate   DateTime?
  endDate     DateTime?
  validDays   Int[] // [1,2,3,4,5] = Mon-Fri
  validHours  String? // "09:00-17:00"
  isRecurring Boolean   @default(true) // Engångskort vs pågående

  // Expiry
  stampsExpireDays Int? // Stämplar går ut efter X dagar
  pointsExpireDays Int?

  // Design
  backgroundColor String?
  logoUrl         String?

  // Settings
  welcomeSms     String? @db.Text
  reminderSms    String? @db.Text
  sendWelcomeSms Boolean @default(false)

  // Social media
  facebookUrl  String?
  instagramUrl String?

  // Status
  isActive Boolean @default(true)
  isDraft  Boolean @default(true)

  // Relations
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  loyaltyCards LoyaltyCard[]
  rewards      Reward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, code])
  @@index([clinicId])
  @@index([isActive])
}

// LoyaltyCard - Kundspecifikt stämpelkort
model LoyaltyCard {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  programId String
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  // Points & stamps
  stamps Int    @default(0)
  points Int    @default(0)
  level  String @default("bronze") // "bronze" | "silver" | "gold"

  // Expiry
  expiresAt    DateTime?
  lastEarnedAt DateTime?

  // Status
  isActive      Boolean   @default(true)
  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, programId])
  @@index([customerId])
  @@index([programId])
  @@index([isActive])
}

// Campaign - SMS/Email-kampanjer
model Campaign {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  // Channel
  channel String @default("sms") // "sms" | "email" | "push" | "whatsapp"

  // Template
  templateId String?
  subject    String? // För email
  body       String  @db.Text

  // Segmentation
  segmentQuery   Json // { tags: ["high-ltv"], stampsMin: 5, churnRisk: "high" }
  estimatedReach Int? // Antal mottagare vid skapande
  actualReach    Int? // Faktiskt antal skickade

  // Scheduling
  scheduleType  String    @default("immediate") // "immediate" | "scheduled" | "recurring"
  scheduleAt    DateTime?
  recurringRule Json? // { frequency: "weekly", dayOfWeek: 4, hour: 18 }

  // Goal
  goal     String? // "retention" | "reactivation" | "promotion" | "capacity_fill"
  category String? // "Uppmuntra återbesök", "Reaktivera inaktiva", etc.

  // Status
  status String @default("draft") // "draft" | "scheduled" | "sending" | "sent" | "cancelled" | "failed"

  // Stats
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  failedCount    Int @default(0)
  clickedCount   Int @default(0)
  redeemedCount  Int @default(0)
  optOutCount    Int @default(0)

  // Cost & ROI
  costSEK    Float?
  revenueSEK Float? // Tracked incremental revenue
  roas       Float? // Return on Ad Spend

  // AI-generated
  isAiGenerated Boolean @default(false)
  aiPrompt      String? @db.Text
  aiVariants    Json? // Array av AI-genererade varianter

  // Relations
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  messages Message[]
  smsLogs  SMSLog[]

  // Timestamps
  sentAt      DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clinicId])
  @@index([status])
  @@index([scheduleAt])
  @@index([channel])
}

// Message - Individuellt meddelande till kund
model Message {
  id         String    @id @default(cuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Content
  channel String // "sms" | "email"
  subject String?
  body    String  @db.Text

  // Delivery
  status String  @default("pending") // "pending" | "sent" | "delivered" | "failed" | "clicked" | "redeemed"
  to     String // Phone or email
  from   String? // Sender

  // Provider tracking
  providerId   String? // External provider message ID
  providerName String? // "46elks" | "Twilio"
  errorMessage String? @db.Text

  // Engagement tracking
  sentAt      DateTime?
  deliveredAt DateTime?
  clickedAt   DateTime?
  redeemedAt  DateTime?

  // Cost
  costSEK Float?

  // Relations
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@index([sentAt])
}

// Reward - Belöningar i lojalitetsprogram
model Reward {
  id        String         @id @default(cuid())
  programId String
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  // Requirements
  requiredStamps Int?
  requiredPoints Int?

  // Value
  valueSEK        Float
  discountPercent Float?
  freeProduct     String?
  freeService     String?

  // Validity
  expiresDays Int? // Går ut X dagar efter inlösen

  // Limits
  maxRedemptions Int? // Max antal inlösningar per kund
  totalAvailable Int? // Totalt antal tillgängliga
  totalRedeemed  Int  @default(0)

  // Status
  isActive Boolean @default(true)

  redemptions Redemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
  @@index([isActive])
}

// Redemption - Inlösen av belöning
model Redemption {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  campaignId String? // Om inlösen kom från kampanj

  // Value
  valueSEK Float

  // Verification
  verifiedBy       String? // Staff user ID eller QR code
  verificationCode String?
  qrCode           String?

  // Status
  status String @default("pending") // "pending" | "verified" | "used" | "expired" | "cancelled"

  // Timestamps
  redeemedAt DateTime  @default(now())
  verifiedAt DateTime?
  usedAt     DateTime?
  expiresAt  DateTime?

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([customerId])
  @@index([rewardId])
  @@index([status])
}

// Event - Tracking av kundaktiviteter
model Event {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type String // "stamp_earned" | "booking_created" | "no_show" | "ad_click" | "sms_sent" | "sms_clicked"

  // Metadata
  meta Json? // { booking_id, amount, service, etc. }

  // Source
  source   String? // "bokadirekt" | "zoezi" | "manual" | "campaign"
  sourceId String?

  // Value
  valueSEK Float?

  occurredAt DateTime @default(now())

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([customerId])
  @@index([type])
  @@index([occurredAt])
}

// OptOut - GDPR opt-out tracking
model OptOut {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  channel String // "sms" | "email" | "all"
  reason  String?

  optedOutAt DateTime @default(now())

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([customerId])
  @@index([channel])
}

// ImportJob - Tracking av data-importer (Zoezi, manuella filer)
model ImportJob {
  id       String  @id @default(cuid())
  source   String // "zoezi" | "manual" | "bokadirekt" | "excel"
  fileName String?
  fileUrl  String?

  // Status
  status String @default("pending") // "pending" | "processing" | "completed" | "failed"

  // Progress
  totalRows      Int?
  processedRows  Int  @default(0)
  successfulRows Int  @default(0)
  failedRows     Int  @default(0)

  // Errors
  errors   Json? // Array av fel-meddelanden
  errorLog String? @db.Text

  // Results
  customersCreated Int @default(0)
  customersUpdated Int @default(0)
  customersSkipped Int @default(0)

  // Timestamps
  startedAt   DateTime?
  completedAt DateTime?

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([status])
  @@index([source])
}

// SMSProviderConfig - Modulär SMS-provider konfiguration
model SMSProviderConfig {
  id        String  @id @default(cuid())
  provider  String // "46elks" | "Twilio" | "Sinch"
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  // Credentials (encrypted)
  apiKey     String
  apiSecret  String?
  fromNumber String // +46701234567

  // Settings
  config Json? // Provider-specific settings

  // Stats
  messagesSent      Int   @default(0)
  messagesDelivered Int   @default(0)
  messagesFailed    Int   @default(0)
  totalCostSEK      Float @default(0)

  // Rate limits
  rateLimitPerHour Int?
  rateLimitPerDay  Int?

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([provider])
  @@index([isPrimary])
}

// SMSCampaign - Track SMS campaigns and messages
model SMSCampaign {
  id         String  @id @default(cuid())
  name       String
  message    String  @db.Text
  templateId String?

  // Recipients
  recipientCount Int @default(0)
  successCount   Int @default(0)
  failedCount    Int @default(0)

  // Scheduling
  scheduledAt DateTime?
  sentAt      DateTime?

  // Cost tracking
  totalCost Float?

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([sentAt])
}

// LoyaltyTransaction - Track stamp and point transactions
model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type        String // "stamp_earned" | "points_earned" | "reward_redeemed"
  stamps      Int     @default(0)
  points      Int     @default(0)
  description String? @db.Text

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([clinicId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// SMS COMPLIANCE & TRACKING (PRIORITY 1)
// ============================================

// SMSLog - Complete audit trail for all SMS communications
model SMSLog {
  id       String @id @default(cuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Message details
  direction String // "outbound" | "inbound"
  from      String
  to        String
  message   String @db.Text

  // Provider details
  provider       String // "46elks" | "twilio"
  providerId     String? // External message ID from provider
  providerStatus String? // Provider-specific status

  // Status tracking
  status        String    @default("pending") // "pending" | "sent" | "delivered" | "failed" | "stopped"
  deliveredAt   DateTime?
  failedAt      DateTime?
  failureReason String?   @db.Text

  // Cost tracking
  cost  Float?
  parts Int    @default(1) // Number of SMS parts

  // Customer relation
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Campaign relation
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  // Retry tracking
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  nextRetryAt DateTime?

  // Metadata
  metadata Json? // Additional provider-specific data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([customerId])
  @@index([campaignId])
  @@index([status])
  @@index([direction])
  @@index([providerId])
  @@index([createdAt])
}

// SMSRateLimit - Track rate limiting per clinic
model SMSRateLimit {
  id       String @id @default(cuid())
  clinicId String @unique
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Rate limit configuration
  maxPerHour  Int @default(100)
  maxPerDay   Int @default(500)
  maxPerMonth Int @default(10000)

  // Current usage
  sentThisHour  Int @default(0)
  sentToday     Int @default(0)
  sentThisMonth Int @default(0)

  // Reset timestamps
  hourResetAt  DateTime
  dayResetAt   DateTime
  monthResetAt DateTime

  // Budget tracking
  budgetSEK      Float?
  spentThisMonth Float  @default(0)

  // Alerts
  alertAt80Percent  Boolean   @default(true)
  alertAt100Percent Boolean   @default(true)
  lastAlertSent     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

// CustomerCommunicationPreference - Granular consent and preferences
model CustomerCommunicationPreference {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Channel preferences
  smsEnabled   Boolean @default(true)
  emailEnabled Boolean @default(true)
  pushEnabled  Boolean @default(false)

  // Category preferences
  transactional Boolean @default(true) // Booking confirmations, receipts
  marketing     Boolean @default(false) // Promotions, offers
  loyalty       Boolean @default(false) // Loyalty program updates
  reminders     Boolean @default(true) // Appointment reminders
  surveys       Boolean @default(false) // Feedback requests

  // Quiet hours
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String? // "22:00"
  quietHoursEnd     String? // "08:00"

  // Frequency limits
  maxPerDay  Int? @default(3)
  maxPerWeek Int? @default(10)

  // GDPR compliance
  consentGivenAt   DateTime?
  consentMethod    String? // "web_form" | "sms_reply" | "in_person" | "import"
  consentIpAddress String?
  consentUpdatedAt DateTime?

  // Opt-out tracking
  optedOutAt   DateTime?
  optOutMethod String? // "sms_stop" | "web_form" | "support_request"
  optOutReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([smsEnabled])
  @@index([marketing])
}

// SMSTemplate - Reusable SMS templates with variables
model SMSTemplate {
  id       String @id @default(cuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  category    String // "welcome" | "reminder" | "promotion" | "loyalty" | "reactivation"

  // Template content
  message   String   @db.Text
  variables String[] @default([]) // ["firstName", "stampsNeeded", "rewardName"]

  // A/B testing
  isVariant   Boolean @default(false)
  parentId    String? // Reference to parent template for A/B test
  variantName String? // "A" | "B" | "C"

  // Performance tracking
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  clickedCount   Int @default(0)
  convertedCount Int @default(0)
  optOutCount    Int @default(0)

  // Calculated metrics
  deliveryRate   Float? // deliveredCount / sentCount
  conversionRate Float? // convertedCount / deliveredCount
  optOutRate     Float? // optOutCount / deliveredCount

  // Status
  isActive Boolean @default(true)
  isDraft  Boolean @default(false)

  // Compliance
  requiresConsent Boolean @default(true)
  consentType     String? // "marketing" | "loyalty" | "transactional"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([category])
  @@index([isActive])
  @@index([isVariant])
}

// SMSStopKeyword - Track STOP keywords and auto-responses
model SMSStopKeyword {
  id       String  @id @default(cuid())
  keyword  String  @unique // "STOP", "STOPP", "SLUTA", "AVSLUTA", etc.
  isActive Boolean @default(true)
  language String  @default("sv") // "sv" | "en"

  // Auto-response
  responseMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyword])
  @@index([isActive])
}

// ============================================
// CUSTOMER INTELLIGENCE & TAG MANAGEMENT
// Wave 4 - Customer Intelligence Hub + Newsletter
// ============================================

enum TagSource {
  BOOKING_SYSTEM // Synced from booking system
  XLS_IMPORT // Imported from Excel/CSV
  AUTO // Auto-generated by Flow AI
  MANUAL // Manually created by user
}

// Tag - Master list of available tags
model Tag {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name        String // "VIP", "Inactive", "New Customer"
  description String? @db.Text
  color       String? // Hex color for UI
  icon        String? // Icon name for UI

  // Auto-tagging rules (if applicable)
  isAutoTag   Boolean @default(false)
  autoTagRule Json? // { totalVisits: ">10", totalSpend: ">5000" }

  // Stats
  customerCount Int @default(0)

  isActive Boolean @default(true)

  customerTags CustomerTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, name])
  @@index([clinicId])
  @@index([isActive])
}

// CustomerTag - Many-to-many relationship with source tracking
model CustomerTag {
  id         String    @id @default(cuid())
  customerId String
  tagId      String
  source     TagSource @default(MANUAL)

  // Metadata
  sourceReference String? // Reference to booking system ID or import job ID
  appliedAt       DateTime @default(now())
  appliedBy       String? // User ID who applied the tag (if manual)

  // Auto-tag tracking
  autoTaggedAt   DateTime?
  lastVerifiedAt DateTime? // When auto-tag rule was last checked

  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, tagId])
  @@index([customerId])
  @@index([tagId])
  @@index([source])
}

// CustomerSegment - Saved customer segments for targeting
model CustomerSegment {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name        String
  description String? @db.Text

  // Filter rules (JSON)
  filters Json // { tags: ["VIP"], ltvMin: 10000, churnRisk: "HIGH" }

  // Stats (cached for performance)
  customerCount Int     @default(0)
  totalValue    Decimal @default(0) @db.Decimal(12, 2)

  // Last calculation
  lastCalculatedAt DateTime?

  // Usage
  isActive   Boolean @default(true)
  usageCount Int     @default(0) // How many campaigns used this segment

  newsletters Newsletter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([isActive])
}

// Newsletter - Email/SMS newsletter campaigns
model Newsletter {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name        String
  description String? @db.Text

  // Content
  subject     String? // For email
  contentHtml String  @db.Text // HTML content for email
  contentText String? @db.Text // Plain text version
  contentSms  String? @db.Text // SMS version (max 160 chars)

  // Channels
  sendChannels String[] @default(["email"]) // ["email", "sms", "push"]

  // Segmentation
  segmentId  String?
  segment    CustomerSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  tagFilters String[]         @default([]) // Additional tag filters

  // Scheduling
  status      NewsletterStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?

  // A/B Testing
  isAbTest    Boolean @default(false)
  variantName String? // "A" | "B" | "Control"
  parentId    String? // Reference to parent newsletter for A/B test

  // Stats
  recipientCount    Int @default(0)
  sentCount         Int @default(0)
  deliveredCount    Int @default(0)
  openedCount       Int @default(0)
  clickedCount      Int @default(0)
  unsubscribedCount Int @default(0)

  // Calculated metrics
  deliveryRate    Float? // deliveredCount / sentCount
  openRate        Float? // openedCount / deliveredCount
  clickRate       Float? // clickedCount / openedCount
  unsubscribeRate Float? // unsubscribedCount / deliveredCount

  // Cost & ROI
  costSEK    Float?
  revenueSEK Float? // Tracked conversions
  roiPercent Float? // (revenue - cost) / cost * 100

  // Template
  templateId String? // Reference to SMSTemplate if used

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([status])
  @@index([segmentId])
  @@index([scheduledAt])
}

enum NewsletterStatus {
  DRAFT // Being edited
  SCHEDULED // Scheduled for sending
  SENDING // Currently being sent
  SENT // Completed
  PAUSED // Paused mid-send
  CANCELLED // Cancelled before sending
  FAILED // Failed to send
}

// NewsletterSubscriber - Track newsletter subscriptions separately from general comms
model NewsletterSubscriber {
  id         String @id @default(cuid())
  clinicId   String
  clinic     Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customerId String

  // Subscription status
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  isActive       Boolean   @default(true)

  // Channel preferences for newsletters
  channels String[] @default(["email"]) // ["sms", "email", "push"]

  // Frequency preference
  frequency String @default("weekly") // "daily" | "weekly" | "monthly"

  // Interests/categories
  interests String[] @default([]) // ["promotions", "tips", "news"]

  // Unsubscribe tracking
  unsubscribeReason String? @db.Text
  unsubscribeMethod String? // "email_link" | "sms_reply" | "support"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, customerId])
  @@index([clinicId])
  @@index([customerId])
  @@index([isActive])
}

// ============================================
// BILLING & SUBSCRIPTION MANAGEMENT
// Wave 4D - October 2025
// ============================================

model Subscription {
  id       String @id @default(cuid())
  clinicId String @unique
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  tier   SubscriptionTier
  status SubscriptionStatus

  // Stripe integration
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Billing cycle
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialStart         DateTime?
  trialEnd           DateTime?
  cancelledAt        DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  // Usage tracking
  bookingsThisMonth Int  @default(0)
  bookingsLimit     Int? // null = unlimited

  // Pricing
  monthlyPrice Decimal @db.Decimal(10, 2)
  currency     String  @default("SEK")

  // Relationships
  invoices      Invoice[]
  payments      Payment[]
  billingAlerts BillingAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([status])
  @@index([stripeSubscriptionId])
}

model Invoice {
  id             String       @id @default(cuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Invoice details
  invoiceNumber String        @unique // INV-2025-001
  status        InvoiceStatus

  // Stripe
  stripeInvoiceId  String? @unique
  hostedInvoiceUrl String? // Stripe-hosted invoice URL
  invoicePdfUrl    String? // PDF download URL

  // Amounts
  subtotal   Decimal @db.Decimal(10, 2)
  tax        Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)
  amountPaid Decimal @default(0) @db.Decimal(10, 2)
  amountDue  Decimal @db.Decimal(10, 2)
  currency   String  @default("SEK")

  // Line items (JSON)
  lineItems Json // [{description, quantity, unitPrice, amount}]

  // Dates
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  paidAt      DateTime?

  // Relationships
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([subscriptionId])
  @@index([status])
  @@index([invoiceNumber])
}

model Payment {
  id             String       @id @default(cuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceId      String?
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // Payment details
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("SEK")
  status        PaymentStatus
  paymentMethod PaymentMethod

  // Stripe
  stripePaymentIntentId String? @unique
  stripeChargeId        String? @unique

  // Payment info
  last4 String? // Last 4 digits of card
  brand String? // visa, mastercard, etc

  // Dates
  attemptedAt   DateTime  @default(now())
  succeededAt   DateTime?
  failedAt      DateTime?
  failureReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([status])
}

model BillingAlert {
  id             String       @id @default(cuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  type       BillingAlertType
  severity   AlertSeverity
  message    String           @db.Text
  resolved   Boolean          @default(false)
  resolvedAt DateTime?

  // Associated data (JSON)
  metadata Json? // {invoiceId, paymentId, etc}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([subscriptionId])
  @@index([resolved])
  @@index([type])
}

