generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/flow/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  firstName            String?
  lastName             String?
  companyName          String?
  jobTitle             String?
  role                 UserRole  @default(STAFF)
  clinicId             String?
  onboardingStep       Int?      @default(0)
  onboardingCompletedAt DateTime?
  clinic               Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  accounts             Account[]
  sessions             Session[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([clinicId])
  @@index([role])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Flow Revenue Intelligence Platform Schema

// Clinic (Salon) - represents a beauty/health clinic using Bokadirekt
model Clinic {
  id                String     @id @default(cuid())
  bokadirektId      String?    @unique // Bokadirekt salon ID
  bokadirektApiKey  String?    // Each clinic has their own API key
  name              String
  description       String?
  address           String?
  phone             String?
  email             String?
  website           String?
  tier              SubscriptionTier @default(BASIC)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt       DateTime?
  subscriptionEndsAt DateTime?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  users             User[]
  customers         Customer[]
  staff             Staff[]
  services          Service[]
  bookings          Booking[]

  @@index([bokadirektId])
  @@index([name])
  @@index([tier])
  @@index([subscriptionStatus])
}

model Customer {
  id             String    @id @default(cuid())
  bokadirektId   String?   @unique // Bokadirekt customer ID
  clinicId       String?
  name           String?
  phone          String?
  email          String?
  tags           String[]  @default([])
  dateOfBirth    DateTime?
  city           String?
  postalCode     String?
  firstName      String?
  lastName       String?
  firstVisit     DateTime?
  totalBookings  Int       @default(0)
  noShowCount    Int       @default(0)
  totalSpent     Decimal   @default(0) @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  clinic         Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  bookings       Booking[]

  @@index([bokadirektId])
  @@index([clinicId])
  @@index([email])
  @@index([phone])
  @@index([name])
}

model Staff {
  id              String    @id @default(cuid())
  bokadirektId    String?   @unique // Bokadirekt resource ID
  clinicId        String?
  name            String
  email           String?
  phone           String?
  role            String?   // E.g., "Hudterapeut", "Massageterapeut"
  specializations String[]  @default([])
  specialization  String?
  hourlyRate      Decimal?  @db.Decimal(8, 2)
  weeklyHours     Int?      // Antal arbetstimmar per vecka
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  clinic          Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  bookings        Booking[]

  @@index([bokadirektId])
  @@index([clinicId])
  @@index([name])
  @@index([specialization])
}

model Room {
  id            String    @id @default(cuid())
  name          String
  equipmentType String?
  available     Boolean   @default(true)
  capacity      Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]

  @@index([name])
  @@index([equipmentType])
}

model Service {
  id           String    @id @default(cuid())
  bokadirektId String?   @unique // Bokadirekt service ID
  clinicId     String?
  name         String
  description  String?
  category     String    @default("general")
  price        Decimal   @default(0) @db.Decimal(10, 2)
  duration     Int       @default(60) // Duration in minutes
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  clinic       Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  bookings     Booking[]

  @@index([bokadirektId])
  @@index([clinicId])
  @@index([name])
  @@index([category])
}

model Booking {
  id              String        @id @default(cuid())
  bokadirektId    String?       @unique // Bokadirekt booking ID
  clinicId        String?
  customerId      String
  staffId         String?
  serviceId       String?
  roomId          String?
  treatmentType   String        @default("")
  scheduledTime   DateTime
  startTime       DateTime?
  endTime         DateTime?
  duration        Int?          // Duration in minutes
  price           Decimal       @db.Decimal(8, 2)
  revenue         Decimal       @default(0) @db.Decimal(10, 2)
  cost            Decimal       @default(0) @db.Decimal(10, 2)
  source          String?       // 'bokadirekt', 'bokadirekt_online', 'manual', etc.
  bookingChannel  String?       // 'online', 'phone', 'walk-in', etc.
  bookedAt        DateTime      @default(now())
  status          BookingStatus @default(SCHEDULED)
  isOnlineBooking Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clinic   Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff    Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  room     Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([bokadirektId])
  @@index([clinicId])
  @@index([customerId])
  @@index([staffId])
  @@index([serviceId])
  @@index([roomId])
  @@index([scheduledTime])
  @@index([startTime])
  @@index([status])
  @@index([source])
  @@index([treatmentType])
  @@index([bookingChannel])
}

model ImportLog {
  id           String            @id @default(cuid())
  filename     String
  status       ImportStatus      @default(PROCESSING)
  totalRows    Int               @default(0)
  successRows  Int               @default(0)
  errorRows    Int               @default(0)
  errors       String?           @db.Text
  metadata     Json?             // Store column mappings, import settings
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Enums
enum UserRole {
  SUPER_ADMIN      // System owner - can see all clinics
  ADMIN            // Clinic owner - can see their clinic
  STAFF            // Staff member - limited access
  CLINIC_ADMIN     // Legacy - same as ADMIN
  CLINIC_STAFF     // Legacy - same as STAFF
}

enum SubscriptionTier {
  BASIC            // 499 SEK/month
  PROFESSIONAL     // 1499 SEK/month
  ENTERPRISE       // 2999+ SEK/month
}

enum SubscriptionStatus {
  TRIAL            // 14-day free trial
  ACTIVE           // Paying customer
  PAST_DUE         // Payment failed
  CANCELLED        // Subscription cancelled
  EXPIRED          // Trial/subscription expired
}

enum BookingStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
  RESCHEDULED
  completed    // lowercase for Bokadirekt compatibility
  cancelled    // lowercase for Bokadirekt compatibility
  no_show      // lowercase for Bokadirekt compatibility
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}
