// RevenueInsight - Daily/Weekly/Monthly revenue snapshots
model RevenueInsight {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Time period
  period     InsightPeriod  // DAILY, WEEKLY, MONTHLY
  startDate  DateTime
  endDate    DateTime

  // Revenue metrics
  totalRevenue        Decimal @db.Decimal(12, 2)
  recurringRevenue    Decimal @db.Decimal(12, 2) // MRR if monthly
  newRevenue          Decimal @db.Decimal(12, 2) // From new customers
  expansionRevenue    Decimal @db.Decimal(12, 2) // Upsells
  churnedRevenue      Decimal @db.Decimal(12, 2) // Lost revenue

  // Customer metrics
  totalCustomers      Int
  newCustomers        Int
  activeCustomers     Int
  churnedCustomers    Int
  reactivatedCustomers Int

  // Booking metrics
  totalBookings       Int
  completedBookings   Int
  cancelledBookings   Int
  noShowBookings      Int

  // Calculated metrics
  averageRevenuePerUser     Decimal  @db.Decimal(10, 2) // ARPU
  averageBookingValue       Decimal  @db.Decimal(10, 2)
  customerLifetimeValue     Decimal? @db.Decimal(10, 2)
  churnRate                 Decimal? @db.Decimal(5, 4) // Percentage
  growthRate                Decimal? @db.Decimal(5, 4) // % growth from previous period
  
  // Capacity metrics
  utilizationRate      Decimal? @db.Decimal(5, 2) // % of available slots booked
  peakHours            Json?    // Array of busiest hours
  slowHours            Json?    // Array of slowest hours

  // Metadata
  calculatedAt DateTime @default(now())
  metadata     Json?    // Additional metrics

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, period, startDate])
  @@index([clinicId])
  @@index([period])
  @@index([startDate])
}

enum InsightPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum HealthStatus {
  CRITICAL      // 0-25: High churn risk
  AT_RISK       // 26-50: Needs attention
  HEALTHY       // 51-75: Good standing
  EXCELLENT     // 76-100: VIP status
}

