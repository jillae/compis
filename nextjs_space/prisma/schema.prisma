// BankConnection - Plaid bank account connections
model BankConnection {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  // Plaid Item data
  itemId          String   @unique // Plaid Item ID (unique per bank connection)
  accessToken     String   // Plaid Access Token (encrypted)
  institutionId   String   // Bank institution ID (e.g., "ins_109508")
  institutionName String   // Human-readable bank name (e.g., "Chase")
  
  // Connection status
  status          BankConnectionStatus @default(PENDING)
  
  // Account IDs (multiple accounts can be linked per item)
  accountIds      String[] @default([]) // Array of Plaid account IDs
  
  // Metadata
  cursor          String?  // Cursor for incremental transaction sync
  lastSyncedAt    DateTime? // Last time transactions were synced
  expiresAt       DateTime? // Access token expiration (if applicable)
  
  // Sync tracking
  lastSyncAt      DateTime?
  lastSyncStatus  String?  @default("pending") // "success", "failed", "pending"
  lastSyncError   String?  @db.Text
  
  // Relations
  transactions    BankTransaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([clinicId])
  @@index([status])
  @@index([itemId])
}

// BankTransaction - Transactions from connected bank accounts
model BankTransaction {
  id                    String         @id @default(cuid())
  bankConnectionId      String?        // Optional - only for Plaid
  bankConnection        BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)
  clinicId              String
  clinic                Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  // Source identification
  source                String         @default("plaid") // "plaid" or "fortnox"
  externalId            String?        // External ID from source system
  
  // Plaid transaction data
  transactionId         String?        // Plaid transaction ID (not unique anymore since Fortnox also uses this table)
  accountId             String?        // Which Plaid account this transaction belongs to
  
  // Transaction details
  transactionDate       DateTime       // Unified date field for all sources
  amount                Decimal        @db.Decimal(12, 2)
  currency              String         @default("SEK")
  bookingDate           DateTime?      // Date transaction was booked (Plaid)
  valueDate             DateTime?      // Date transaction value was applied (Plaid)
  
  // Description & categorization
  description           String?        @db.Text // Unified description field
  remittanceInformation String?        @db.Text // Payment description (Plaid)
  reference             String?        // Reference number (Fortnox)
  debtorName            String?        // Who paid (if incoming)
  creditorName          String?        // Who received (if outgoing)
  accountNumber         String?        // Bank account number (Fortnox)
  balance               Decimal?       @db.Decimal(12, 2) // Account balance after transaction (Fortnox)
  
  // Transaction type
  transactionType       String?        // "DEBIT" or "CREDIT"
  proprietaryCode       String?        // Bank-specific code
  
  // Flow categorization (AI-enhanced)
  category              String?        // "booking_revenue", "expense", "other"
  isReconciled          Boolean        @default(false) // Matched to a booking/expense
  reconciledBookingId   String?        // If matched to a booking
  
  // Sales matching (for Fortnox bank transactions)
  matchedToSaleId       String?        // Link to matched Sale
  matchedSale           Sale?          @relation(fields: [matchedToSaleId], references: [id])
  matchStatus           String         @default("unmatched") // "matched", "unmatched", "manual"
  
  // AI analysis
  aiConfidence          Decimal?       @db.Decimal(5, 4) // 0.0 to 1.0
  aiSuggestions         Json?          // AI suggestions for categorization
  
  // Metadata
  metadata              Json?          // Raw data from source
  
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  
  @@unique([source, externalId])
  @@index([bankConnectionId])
  @@index([clinicId])
  @@index([transactionDate])
  @@index([bookingDate])
  @@index([category])
  @@index([isReconciled])
  @@index([matchStatus])
  @@index([matchedToSaleId])
}

// BankConnectionStatus enum
enum BankConnectionStatus {
  PENDING   // Waiting for user to authorize
  ACTIVE    // Successfully connected
  EXPIRED   // Requisition expired (90 days)
  SUSPENDED // Temporarily disabled
  ERROR     // Connection error
}

