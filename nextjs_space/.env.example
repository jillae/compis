
# =============================================================================
# KLINIK FLOW CONTROL - ENVIRONMENT VARIABLES
# =============================================================================
# Last updated: 2025-10-22
# 
# INSTRUCTIONS:
# 1. Copy this file to `.env` in the same directory
# 2. Fill in all values marked with YOUR_*
# 3. NEVER commit `.env` to git (it's in .gitignore)
# 4. Rotate all secrets regularly (see SECURITY_ROTATION_GUIDE.md)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?connect_timeout=15
DATABASE_URL='postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE?connect_timeout=15'

# -----------------------------------------------------------------------------
# NEXTAUTH (Authentication)
# -----------------------------------------------------------------------------
# NextAuth secret key (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET='YOUR_NEXTAUTH_SECRET_KEY_HERE'

# NextAuth URL (production: https://goto.klinikflow.app, local: http://localhost:3000)
NEXTAUTH_URL='http://localhost:3000'

# -----------------------------------------------------------------------------
# GOOGLE SSO (Optional)
# -----------------------------------------------------------------------------
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID='YOUR_GOOGLE_CLIENT_ID'
GOOGLE_CLIENT_SECRET='YOUR_GOOGLE_CLIENT_SECRET'

# -----------------------------------------------------------------------------
# AWS S3 STORAGE
# -----------------------------------------------------------------------------
# AWS credentials for file uploads (profile-based auth used in production)
AWS_PROFILE='hosted_storage'
AWS_REGION='us-west-2'
AWS_BUCKET_NAME='YOUR_BUCKET_NAME'
AWS_FOLDER_PREFIX='YOUR_FOLDER_PREFIX/'

# -----------------------------------------------------------------------------
# BOKADIREKT API
# -----------------------------------------------------------------------------
# Get API key from: https://external.api.portal.bokadirekt.se
BOKADIREKT_API_KEY='YOUR_BOKADIREKT_API_KEY'
BOKADIREKT_API_URL='https://external.api.portal.bokadirekt.se/api/v1'

# -----------------------------------------------------------------------------
# CRON JOBS
# -----------------------------------------------------------------------------
# Secret for authenticating cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET='YOUR_CRON_SECRET_HERE'

# -----------------------------------------------------------------------------
# EMAIL (RESEND)
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY='YOUR_RESEND_API_KEY'

# -----------------------------------------------------------------------------
# META MARKETING API (Facebook/Instagram Ads)
# -----------------------------------------------------------------------------
# CRITICAL: Use System User Token (never expires)
# Get from: https://business.facebook.com → Business Settings → System Users
# Permissions needed: ads_read, ads_management, ads_creative_read
META_ACCESS_TOKEN='YOUR_META_SYSTEM_USER_TOKEN'
META_AD_ACCOUNT_ID='YOUR_AD_ACCOUNT_ID'
META_PIXEL_ID='YOUR_PIXEL_ID'
META_APP_ID='YOUR_APP_ID'
META_APP_SECRET='YOUR_APP_SECRET'

# Meta Webhook Verify Token (generate with: openssl rand -hex 32)
META_WEBHOOK_VERIFY_TOKEN='YOUR_META_WEBHOOK_VERIFY_TOKEN'

# -----------------------------------------------------------------------------
# ABACUS AI (LLM API)
# -----------------------------------------------------------------------------
# Get API key from: https://abacus.ai
ABACUSAI_API_KEY='YOUR_ABACUSAI_API_KEY'

# -----------------------------------------------------------------------------
# 46ELKS (SMS)
# -----------------------------------------------------------------------------
# Get credentials from: https://46elks.com/dashboard
FORTYSEVEN_ELKS_API_USERNAME='YOUR_46ELKS_USERNAME'
FORTYSEVEN_ELKS_API_PASSWORD='YOUR_46ELKS_PASSWORD'

# -----------------------------------------------------------------------------
# PLAID (Bank Integration)
# -----------------------------------------------------------------------------
# Get credentials from: https://dashboard.plaid.com
# NOTE: PLAID_ENV can be 'sandbox', 'development', or 'production'
PLAID_CLIENT_ID='YOUR_PLAID_CLIENT_ID'
PLAID_SECRET='YOUR_PLAID_SECRET'
PLAID_ENV='sandbox'

# -----------------------------------------------------------------------------
# GOHIGHLEVEL (CRM Integration)
# -----------------------------------------------------------------------------
# Get credentials from: https://app.gohighlevel.com
# API Key is a JWT token (long string starting with eyJ...)
GHL_API_KEY='YOUR_GHL_API_KEY'
GHL_LOCATION_ID='YOUR_GHL_LOCATION_ID'

# -----------------------------------------------------------------------------
# FORTNOX (Accounting Integration) - Optional
# -----------------------------------------------------------------------------
# Get credentials from: https://apps.fortnox.se
# Only needed if using Fortnox integration
# FORTNOX_CLIENT_ID='YOUR_FORTNOX_CLIENT_ID'
# FORTNOX_CLIENT_SECRET='YOUR_FORTNOX_CLIENT_SECRET'

# -----------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# -----------------------------------------------------------------------------

# Stripe (for payment processing)
# STRIPE_SECRET_KEY='YOUR_STRIPE_SECRET_KEY'
# STRIPE_WEBHOOK_SECRET='YOUR_STRIPE_WEBHOOK_SECRET'

# Clockify (for time tracking)
# CLOCKIFY_API_KEY='YOUR_CLOCKIFY_API_KEY'

# GoCardless (for recurring payments)
# GOCARDLESS_ACCESS_TOKEN='YOUR_GOCARDLESS_ACCESS_TOKEN'
# GOCARDLESS_ENV='sandbox' # or 'live'

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 
# SECURITY REMINDERS:
# - NEVER commit .env files to git
# - Rotate all secrets every 90 days (see SECURITY_ROTATION_GUIDE.md)
# - Use System User tokens for Meta (never expire)
# - Use environment-specific values (sandbox vs production)
# 
# DEPLOYMENT:
# - Production: goto.klinikflow.app uses different secrets
# - Staging: Use separate credentials for testing
# - Local: Use sandbox/test credentials
# 
# TROUBLESHOOTING:
# - If build fails: Check that all required variables are set
# - If API calls fail: Verify credentials are correct
# - If webhooks fail: Check that URLs are publicly accessible
# 
# =============================================================================
