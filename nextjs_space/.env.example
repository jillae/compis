
# ==============================================
# KLINIK FLOW - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# DATABASE (Supabase/PostgreSQL)
# ============================================
# Get from: Supabase Dashboard → Settings → Database → Connection String
# Format: postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres
DATABASE_URL=

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your app URL (change for production)
NEXTAUTH_URL=http://localhost:3000

# ============================================
# GOOGLE OAUTH (Optional)
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# AWS S3 STORAGE (File Uploads)
# ============================================
# Provided by hosting platform or your AWS account
AWS_PROFILE=hosted_storage
AWS_REGION=us-west-2
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=

# ============================================
# BOKADIREKT INTEGRATION
# ============================================
# Get from: Bokadirekt Partner Portal
BOKADIREKT_API_KEY=
BOKADIREKT_API_URL=https://external.api.portal.bokadirekt.se/api/v1

# ============================================
# META MARKETING API (Facebook/Instagram)
# ============================================
# Get from: https://developers.facebook.com/apps
# 1. Create App → Business Type
# 2. Settings → Basic → App ID & App Secret
# 3. Marketing API → System User → Generate Token
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
META_APP_ID=
META_APP_SECRET=

# Meta Webhook Verification Token (you create this - any random string)
META_WEBHOOK_VERIFY_TOKEN=

# ============================================
# EMAIL SERVICE (Resend)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# ============================================
# SMS SERVICE (46elks)
# ============================================
# Get from: https://46elks.com/
FORTYSEVEN_ELKS_API_USERNAME=
FORTYSEVEN_ELKS_API_PASSWORD=

# ============================================
# AI/LLM API (Abacus Route LLM)
# ============================================
# Get from: Abacus.AI Dashboard
ABACUSAI_API_KEY=
ABACUSAI_BASE_URL=https://apis.abacus.ai/

# ============================================
# CRON JOBS PROTECTION
# ============================================
# Create a random secret to protect cron endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# GoCardless (Bank Integration)
# GOCARDLESS_ACCESS_TOKEN=
# GOCARDLESS_SECRET_ID=
# GOCARDLESS_SECRET_KEY=

# Fortnox (Accounting)
# FORTNOX_CLIENT_ID=
# FORTNOX_CLIENT_SECRET=
# FORTNOX_ACCESS_TOKEN=

# Plaid (US Bank Integration)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# ============================================
# DEVELOPMENT/DEBUGGING
# ============================================
# Uncomment for verbose logging
# DEBUG=true
# NODE_ENV=development
