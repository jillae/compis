  "philosophy": {
    "archmethod": {
      "title": "Archmethod® - Neurocentrerat perspektiv",
      "description": "Archmethod är en neurobaserad approach till smärta och hälsa. Vi ser smärta som en överlevnadsreflex från nervsystemet, inte som ett strukturellt fel i kroppen. Detta perspektiv möjliggör effektiv behandling genom att arbeta med nervsystemets anpassningsförmåga.",
      "key_principles": [
        "Smärta är en överlevnadsreflex från nervsystemet",
        "Nervsystemet styr smärtupplevelsen",
        "Individuell anpassning av behandling",
        "Helhetsperspektiv på hälsa och funktion",
        "Evidensbaserad och neurocentrerad metodik",
        "Fokus på långsiktig förändring, inte symptombehandling"
      ],
      "scientific_basis": "Baserat på modern smärtforskning och neurovetenskap"
    },
    "neurobaserad": "Neurobaserad Träning | Vardagsstark Vardagsstark PÅ GÅNG Paketpriser SMÄRTA Behandlingar Archmethod®",
    "nervsystem": "kunna hantera dig i din miljö du befinner dig i. Denna träning är i sig ingen direkt behandling men med tanke på att det är din hjärna vi optimerar får vi blixtsnabb respons på övningarna eftersom nervsystemet går med ljusets hastighet. Vad gör vi då? Hjärnan använder sig av 3 \"sateliter\" för att sköta vår kropp: Visuellt: Ögon - hur vi rör och använder våra ögon Vestibular: Hörsel & Balans Proprioception: Allt från känsel till rörelse: Som en karta över din kropp Om någon av dessa sateliter inte fun",
    "smärta är": "hjärnan skickar för signaler via nervsystemet. Så vi utbildar din hjärna! Vi gör dig uppmärksam på din hållning och hur din kropp placerat sig och vad som kan vara orsaken. Vi ger dig kunskap om vad smärta är och varför hjärnan skickar smärtsignaler. En av dem absolut viktigaste kunskaperna du nånsin kommer att lära dig! Vi lär dig Tensigritet och Proprioception - hur allt hänger ihop både muskulärt men även en av nervsystemets viktigaste uppgifter för basala kroppsfunktioner. Vi återutbildar dig och o",
    "överlevnadsreflex": "åtgärdssignal. Därför är det viktigt att informationen som hjärnan tar emot är av så hög kvalité som möjligt, så att den kan tolka det rätt och då ge dig ett bättre utförande. Smärta är därför en överlevnadsreflex. Hjärnan varnar om åtgärd krävs och beroende på vad du tidigare gått igenom i ditt liv och hur du då hanterat det, medvetet eller omedvetet, kommer hjärnan att varna olika mycket beroende på om det tidigare varit ett hot eller inte. Vilket ger mer eller mindre smärta - olika för olika individer. V",
    "treatment_approach": {
      "title": "Behandlingsmetodik",
      "description": "Vi använder en kombination av LLLT (Low-Level Laser Therapy), neurobaserad träning, manuell behandling och individuellt anpassade behandlingsplaner för optimal effekt.",
      "methods": [
        "LLLT (Low-Level Laser Therapy) - Laser för vävnadsläkning",
